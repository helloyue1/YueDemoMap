<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.elderly.apartment.mapper.FeePaymentMapper">

    <resultMap id="BaseResultMap" type="com.elderly.apartment.entity.FeePayment">
        <id column="id" property="id"/>
        <result column="payment_no" property="paymentNo"/>
        <result column="bill_id" property="billId"/>
        <result column="elderly_id" property="elderlyId"/>
        <result column="payment_amount" property="paymentAmount"/>
        <result column="payment_method" property="paymentMethod"/>
        <result column="payment_type" property="paymentType"/>
        <result column="transaction_no" property="transactionNo"/>
        <result column="payer_name" property="payerName"/>
        <result column="payer_phone" property="payerPhone"/>
        <result column="receipt_no" property="receiptNo"/>
        <result column="status" property="status"/>
        <result column="remark" property="remark"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="elderly_name" property="elderlyName"/>
        <result column="bill_no" property="billNo"/>
    </resultMap>

    <select id="selectPaymentList" resultMap="BaseResultMap">
        SELECT fp.*, u.real_name as elderly_name, fb.bill_no
        FROM fee_payment fp
        LEFT JOIN user u ON fp.elderly_id = u.id
        LEFT JOIN fee_bill fb ON fp.bill_id = fb.id
        <where>
            <if test="elderlyName != null and elderlyName != ''">
                AND u.real_name LIKE CONCAT('%', #{elderlyName}, '%')
            </if>
            <if test="startDate != null and startDate != ''">
                AND DATE(fp.create_time) &gt;= #{startDate}
            </if>
            <if test="endDate != null and endDate != ''">
                AND DATE(fp.create_time) &lt;= #{endDate}
            </if>
        </where>
        ORDER BY fp.create_time DESC
    </select>

</mapper>
